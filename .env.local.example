# Live-siege relay (server-side only — NOT exposed to the browser).
# Copy to .env.local and fill in. Used by /api/siege/start and /api/siege/stream.

# A Band agent API key that is a participant of the room (e.g. the Judge's key).
BAND_API_KEY=band_a_...

# A pre-created Band room that already contains the 4 standing agents
# (Crucible-Architect, Crucible-Engineer, Crucible-RedLead, Crucible-Judge).
# The two specialists are recruited at runtime — do NOT pre-add them.
BAND_ROOM_ID=00000000-0000-0000-0000-000000000000

# Optional: override the Band REST base URL.
# BAND_REST_URL=https://app.band.ai

# Optional: override the agent UUID -> handle/side map (JSON) if you registered
# your own agents instead of the defaults baked into src/lib/bandLive.ts.
# BAND_AGENTS_JSON={"<uuid>":{"handle":"@Architect","side":"build"}, ...}
